    "Configure countdown style and lock screen widgets in the Calendar tab.": {
      "comment": "A footer for the \"Enable reminder live activity\" toggle in the Live Activities settings.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 탭에서 카운트다운 스타일과 잠금 화면 위젯을 설정하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
