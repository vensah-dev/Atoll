      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'세그먼트' 모드에서는 색상별 채우기를 사용할 수 없습니다. 고급 옵션을 조정하려면 '제어기 › Dynamic Island'에서 '계층형' 또는 '그라데이션'으로 전환하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
