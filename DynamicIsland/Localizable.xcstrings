    "Disabled while external display integration is active — brightness keys are handled by the external app.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "외부 디스플레이 연동이 활성화된 동안에는 비활성화됩니다. 밝기 키는 외부 앱에서 제어합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "value": "Отключено при активной интеграции внешнего дисплея — клавиши яркости обрабатываются внешним приложением.",
            "state": "translated"
          }
        }
      }
    },
    "Discrete transitions snap between Green (0–60%), Yellow (60–85%), and Red (85–100%).": {
      "comment": "A description of how the color-coded progress bars work when not using smooth transitions.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단계적 전환은 초록색(0~60%), 노란색(60~85%), 빨간색(85~100%) 구간에 맞춰 색상이 즉시 전환됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Transições discretas se encaixam entre Verde (0–60%), Amarelo (60–85%) e Vermelho (85–100%)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключено при активной интеграции BetterDisplay — приложение использует Cmd+Клавиши яркости для своего управления."
          }
        }
      }
    },
