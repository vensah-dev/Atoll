    "Applies the notch-style parallax effect to the lock screen media widget album art.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잠금 화면 미디어 위젯의 앨범 아트에 노치 스타일의 패럴랙스 효과를 적용합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica o efeito de paralaxe ao notch à arte do álbum do widget de mídia da tela de bloqueio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Music"
          }
        }
      }
    },
    "Apps using AtollExtensionKit will appear here once they request permission": {
      "comment": "A description below the placeholder text in the \"Search extensions...\" text field, explaining that apps using AtollExtensionKit will be listed here once they grant permission to use the app.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AtollExtensionKit을 사용하는 앱이 권한을 요청하면 여기에 표시됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicativos usando AtollExtensionKit aparecerão aqui assim que solicitarem permissão"
          }
        },
        "ru": {
          "stringUnit": {
            "value": "Приложения с AtollExtensionKit появятся здесь после запроса разрешения.",
            "state": "translated"
          }
        }
      }
    },
    "AQI": {
      "comment": "Label for the US AQI scale in the lock screen weather view.",
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AQI"
          }
        },
        "ru": {
          "stringUnit": {
            "value": "AQI",
            "state": "translated"
          }
        }
      }
    },
    "Are you sure you want to delete \"%@\"?": {
      "comment": "A confirmation prompt asking the user to confirm the deletion of a custom idle animation. The placeholder text inside the quotation marks should be replaced with the name of the animation.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer \"%@\" ?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"을(를) 삭제하시겠습니까?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir “%@”?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "AQI"
          }
        }
      }
    },
    "Are you sure you want to delete this color from your history?": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer cette couleur de votre historique ?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 색상을 기록에서 삭제하시겠습니까?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir essa cor do seu histórico?"
          }
        },
        "ru": {
          "stringUnit": {
            "value": "Удалить этот цвет из истории?",
            "state": "translated"
          }
        }
      }
    },
    "Ask me anything...": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
