    "Adds a Guake-style dropdown terminal tab. The terminal session persists across notch open/close cycles.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Guake 스타일의 드롭다운 터미널 탭을 추가합니다. 터미널 세션은 노치를 여닫아도 끊기지 않고 유지됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "value": "Добавляет выпадающее окно терминала в стиле Guake. Сессия сохраняется.",
            "state": "translated"
          }
        }
      }
    },
    "Adds a notch HUD when Caps Lock is enabled, with optional label and tint controls.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Caps Lock이 활성화되면 노치 HUD를 추가합니다. 레이블 및 색조 제어 옵션을 제공합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona um HUD no notch quando o Caps Lock está ativado, com controles opcionais de etiqueta e tonalidade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включить выпадающий терминал в стиле Guake. Сессия терминала сохраняется при сворачивании/разворачивании выреза."
          }
        }
      }
    },
    "Adds the AirPlay/route picker button back to the customizable controls palette.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "AirPlay/경로 선택기 버튼을 사용자 지정 제어기 팔레트에 다시 추가합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona o botão AirPlay/seletor de rota de volta à paleta de controles personalizáveis."
          }
        },
        "ru": {
          "stringUnit": {
            "value": "Добавляет кнопку AirPlay/выбора маршрута обратно в палитру.",
            "state": "translated"
          }
        }
      }
    },
    "Adjust settings above to see changes in real-time. The actual OSD appears at the bottom center of your screen.": {
      "comment": "A footer in the \"Preview\" section of the Custom OSD settings, explaining how to use the live preview feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위의 설정을 조정하여 변경 사항을 실시간으로 확인하세요. 실제 OSD는 화면 중앙 하단에 나타납니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste as configurações acima para ver as alterações em tempo real. O OSD real aparece na parte inferior central da tela."
          }
        },
        "ru": {
          "stringUnit": {
            "value": "Настройте параметры выше. OSD появится внизу по центру.",
            "state": "translated"
          }
        }
      }
    },
