      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die integrierte Systemüberwachung erkennt Änderungen der Lautstärke, Helligkeit und Tastaturbeleuchtung direkt, ohne dass externe Apps erforderlich sind."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
